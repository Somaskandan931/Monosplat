# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environment ────────────────────────────────────────────
venv/
.env/
env/

# ── Data (large files — store separately) ──────────────────────────
data/raw/*
data/processed/*
data/colmap_output/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/colmap_output/.gitkeep

# ── Models (large files — use Git LFS or Drive) ────────────────────
models/gaussian/*
models/checkpoints/*
!models/gaussian/.gitkeep
!models/checkpoints/.gitkeep

# ── Outputs ────────────────────────────────────────────────────────
outputs/renders/*
outputs/logs/*
outputs/videos/*
!outputs/renders/.gitkeep
!outputs/logs/.gitkeep
!outputs/videos/.gitkeep

# ── Work directory (job processing files) ──────────────────────────
work/
uploads/

# ── Archives (IMPORTANT: prevent accidental zip uploads to Colab) ──
# Covers: src.zip, cd24904e9fa0_for_colab.zip, and any other archives
*.zip
*.tar
*.gz
*.7z
*.rar
*.tar.gz
*.tar.bz2

# ── Jupyter ────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ───────────────────────────────────────────────────────────
*.log